[sub_resource type="Shader" id="Shader_Background"]
code = "shader_type canvas_item;

void fragment() {
    vec2 center = vec2(0.5, 0.5);
    float dist = distance(UV, center);
    vec3 center_color = vec3(0.12, 0.10, 0.15);
    vec3 edge_color = vec3(0.04, 0.03, 0.05);
    float factor = smoothstep(0.0, 0.8, dist);
    vec3 final_color = mix(center_color, edge_color, factor);
    float noise = (fract(sin(dot(UV ,vec2(12.9898,78.233))) * 43758.5453) - 0.5) * 0.015;
    COLOR = vec4(final_color + noise, 1.0);
}"

