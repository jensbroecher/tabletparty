[sub_resource type="Shader" id="WaterShader"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled;

uniform vec4 water_color : source_color = vec4(0.05, 0.15, 0.28, 0.88);
uniform float wave_speed : hint_range(0.0, 10.0) = 0.15;
uniform float wave_height : hint_range(0.0, 0.2) = 0.0003;
uniform float flow_speed : hint_range(0.0, 2.0) = 0.05;

void vertex() {
    // Small flowing waves (much gentler)
    float wave = sin((VERTEX.x * 2.0 + TIME * wave_speed)) * wave_height;
    wave += sin((VERTEX.x * 3.0 + VERTEX.z * 1.0 + TIME * wave_speed * 1.3)) * wave_height * 0.3;
    VERTEX.y += wave;
}

void fragment() {
    // Flowing pattern (slower, broader)
    vec2 flow_uv = UV;
    flow_uv.x += TIME * flow_speed;
    float flow = sin(flow_uv.x * 5.0) * 0.08 + 0.92;
    ALBEDO = water_color.rgb * flow;
    ALPHA = water_color.a;
    METALLIC = 0.15;
    ROUGHNESS = 0.25;
    SPECULAR = 0.7;
}"

