[node name="StartButton" type="Button" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "CONTINUE"

[connection signal="item_selected" from="VBox/PlayerCount/OptionButton" to="." method="_on_player_count_changed"]
[connection signal="pressed" from="VBox/StartButton" to="." method="_on_start_pressed"]
